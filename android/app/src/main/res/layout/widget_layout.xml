<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <!-- Background (80% Alpha, Match Parent to Fill All) -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_glass_background"
        android:scaleType="fitXY"
        android:alpha="0.8" />

    <!-- Last Updated (Fixed at Bottom, OurHomeTax Spec) -->
    <TextView
        android:id="@+id/txt_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="end"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp"
        android:text="최종 확인: --:--"
        android:textColor="#80FFFFFF"
        android:textSize="8sp" />

    <!-- Initial/Login Mask (Wrapped in Padding Container) -->
    <LinearLayout
        android:id="@+id/txt_login_required"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_widget_logo"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="로그인이 필요합니다."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Content Container (Internal Padding for Data) -->
    <LinearLayout
        android:id="@+id/layout_data_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/txt_last_updated"
        android:orientation="vertical"
        android:gravity="top"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:visibility="visible">

        <!-- Top Row: Logo, Title, Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp">

            <!-- App Logo (Original LToBank Logo) -->
            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_widget_logo"
                android:scaleType="fitCenter"
                android:layout_centerVertical="true" />

            <!-- Title (v40: 14sp) -->
            <TextView
                android:id="@+id/txt_widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_logo"
                android:layout_marginStart="6dp"
                android:text="L.To Bank"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_centerVertical="true" />

            <!-- Pending Badge (OurHomeTax Style) -->
            <LinearLayout
                android:id="@+id/layout_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/badge_background"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/txt_pending_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="승인대기"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/txt_pending_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Bottom Row: Accounts (Balances) -->
        <LinearLayout
            android:id="@+id/layout_accounts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <!-- Left Account (채원) -->
            <LinearLayout
                android:id="@+id/layout_left"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_left_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="채원"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txt_left_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₩ 0"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_left_interest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="(+0)"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right Account (도권) -->
            <LinearLayout
                android:id="@+id/layout_right"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/txt_right_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="도권"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txt_right_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₩ 0"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_right_interest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="(+0)"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
